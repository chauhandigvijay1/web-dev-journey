{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Run C++ File",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-Command",
        "g++ -std=c++17 \"${file}\" -o \"${fileDirname}\\${fileBasenameNoExtension}.exe\"; if ($?) { & \"${fileDirname}\\${fileBasenameNoExtension}.exe\" }"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": []
    }
  ]
}